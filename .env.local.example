# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API

# Safe to expose to the browser — used for auth session management only
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — bypasses Row Level Security. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Get these from: twilio.com → Console → Account Info
# Not needed while ALERT_TEST_MODE=true

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Preferred: use a Messaging Service SID for better deliverability
TWILIO_MESSAGING_SERVICE_SID=

# Fallback: use a single From number if not using a Messaging Service
TWILIO_FROM_NUMBER=

# ─── Alert behavior ───────────────────────────────────────────────────────────
# true  → log alerts to console, do NOT send real SMS (safe default)
# false → send real SMS via Twilio (only set this in production)
ALERT_TEST_MODE=true

# ─── Cron security ────────────────────────────────────────────────────────────
# Random secret string. Vercel sends this as Authorization: Bearer <value>
# when triggering /api/cron/run-alert-check. Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-string

# ─── Weather provider ─────────────────────────────────────────────────────────
# open_meteo is the default (free, no API key required)
WEATHER_PROVIDER=open_meteo
